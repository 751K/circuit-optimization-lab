* circuitopt FreePDK45 full-charge transient
.include "{{FP45}}/models_nom/NMOS_VTG.inc"
.include "{{FP45}}/models_nom/PMOS_VTG.inc"
.options temp=27 method=gear maxord=1
Vrail_VDD n_VDD 0 1
Vrail_vinp n_vinp 0 0.55000000000000004
Vrail_vinn n_vinn 0 0.55000000000000004
Vrail_vbias n_vbias 0 0.55000000000000004
Vgate_M1 n_gate_M1 0 PWL(
+ 0 0.55000000000000004 1.0000000000000001e-09 0.55100000000000005 2.0000000000000001e-09 0.55200000000000005 3.0000000000000004e-09 0.55300000000000005 4.0000000000000002e-09 0.55400000000000005 5.0000000000000001e-09 0.55500000000000005
+ 6.0000000000000008e-09 0.55600000000000005 7.0000000000000006e-09 0.55700000000000005 8.0000000000000005e-09 0.55800000000000005 9.0000000000000012e-09 0.55900000000000005 1e-08 0.56000000000000005)
Vgate_M2 n_gate_M2 0 PWL(
+ 0 0.55000000000000004 1.0000000000000001e-09 0.54900000000000004 2.0000000000000001e-09 0.54800000000000004 3.0000000000000004e-09 0.54700000000000004 4.0000000000000002e-09 0.54600000000000004 5.0000000000000001e-09 0.54500000000000004
+ 6.0000000000000008e-09 0.54400000000000004 7.0000000000000006e-09 0.54300000000000004 8.0000000000000005e-09 0.54200000000000004 9.0000000000000012e-09 0.54100000000000004 1e-08 0.54000000000000004)
M1 n_n1 n_gate_M1 n_tail 0 NMOS_VTG w=0.5u l=0.10000000000000001u nf=1 delvto=0.01
