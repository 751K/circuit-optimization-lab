* circuitopt FreePDK45 full-charge transient
.include "{{FP45}}/models_ff/NMOS_VTG.inc"
.include "{{FP45}}/models_ff/PMOS_VTG.inc"
.options temp=27 method=gear maxord=1
Vrail_VDD n_VDD 0 1
Vrail_VINP n_VINP 0 0.65000000000000002
Vrail_VINN n_VINN 0 0.65000000000000002
Vrail_VCMI n_VCMI 0 0.65000000000000002
Vrail_VCM_REF n_VCM_REF 0 0.5
Vrail_VB_N n_VB_N 0 0.44
Vrail_VB_CN n_VB_CN 0 0.81399999999999995
Vrail_VB_CP n_VB_CP 0 0.34999999999999998
M0 n_TAIL n_VB_N 0 0 NMOS_VTG w=2.1000000000000001u l=0.20000000000000001u nf=1
M1 n_X1 n_G1 n_TAIL 0 NMOS_VTG w=8.1999999999999993u l=0.14999999999999999u nf=1
M2 n_X2 n_G2 n_TAIL 0 NMOS_VTG w=8.1999999999999993u l=0.14999999999999999u nf=1
M3 n_OUTP n_VB_CN n_X1 0 NMOS_VTG w=4.5599999999999996u l=0.10000000000000001u nf=1
M4 n_OUTN n_VB_CN n_X2 0 NMOS_VTG w=4.5599999999999996u l=0.10000000000000001u nf=1
M5 n_OUTP n_VB_CP n_P1 n_VDD PMOS_VTG w=9.0800000000000001u l=0.10000000000000001u nf=1
M6 n_OUTN n_VB_CP n_P2 n_VDD PMOS_VTG w=9.0800000000000001u l=0.10000000000000001u nf=1
M7 n_P1 n_CTRL n_VDD n_VDD PMOS_VTG w=13u l=0.20000000000000001u nf=1
M8 n_P2 n_CTRL n_VDD n_VDD PMOS_VTG w=13u l=0.20000000000000001u nf=1
MS1 n_VDD n_OUTP n_CMT1 0 NMOS_VTG w=1u l=0.10000000000000001u nf=1
MS2 n_CTRL n_VCM_REF n_CMT1 0 NMOS_VTG w=1u l=0.10000000000000001u nf=1
MS3 n_VDD n_OUTN n_CMT2 0 NMOS_VTG w=1u l=0.10000000000000001u nf=1
MS4 n_CTRL n_VCM_REF n_CMT2 0 NMOS_VTG w=1u l=0.10000000000000001u nf=1
MT1 n_CMT1 n_VB_N 0 0 NMOS_VTG w=0.5u l=0.20000000000000001u nf=1
MT2 n_CMT2 n_VB_N 0 0 NMOS_VTG w=0.5u l=0.20000000000000001u nf=1
MD n_CTRL n_CTRL n_VDD n_VDD PMOS_VTG w=4u l=0.20000000000000001u nf=1
RS1 n_VINP n_VSP 1000
RS2 n_VINN n_VSN 1000
RB1 n_G1 n_VCMI 1000000
RB2 n_G2 n_VCMI 1000000
CC1 n_VSP n_G1 2e-12
CC2 n_VSN n_G2 2e-12
CL1 n_OUTP 0 2.0000000000000001e-13
CL2 n_OUTN 0 2.0000000000000001e-13
.control
set wr_singlescale
set wr_vecnames
tran 9.9999999999999986e-10 5.0000000000000001e-09 0 9.9999999999999986e-10
wrdata OUT.dat v(n_G1) v(n_G2) v(n_VSP) v(n_VSN) v(n_TAIL) v(n_X1) v(n_X2) v(n_P1) v(n_P2) v(n_OUTP) v(n_OUTN) v(n_CTRL) v(n_CMT1) v(n_CMT2) i(Vrail_VDD) i(Vrail_VINP) i(Vrail_VINN) i(Vrail_VCMI) i(Vrail_VCM_REF) i(Vrail_VB_N) i(Vrail_VB_CN) i(Vrail_VB_CP)
.endc
.end
