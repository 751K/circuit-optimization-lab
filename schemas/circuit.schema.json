{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/751K/circuit-optimization-lab/schemas/circuit.schema.json",
  "title": "Circuit Optimization Lab Circuit Description",
  "type": "object",
  "additionalProperties": false,
  "required": ["solved", "rails", "devices"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable circuit name."
    },
    "description": {
      "type": "string",
      "description": "Human-readable circuit description."
    },
    "solved": {
      "type": "array",
      "description": "Unknown node names solved by DC/AC/noise/transient.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/name"}
    },
    "rails": {
      "type": "object",
      "description": "Known node mapping. Values are either numeric constants or bias keys.",
      "minProperties": 1,
      "additionalProperties": {
        "oneOf": [
          {"type": "number"},
          {"$ref": "#/$defs/name"}
        ]
      }
    },
    "devices": {
      "type": "array",
      "description": "Transistor devices. Object form may carry W/L/NF/M (M = parallel-instance multiplicity, default 1); array form is [name, drain, gate, source]. Per-device model selection lives in the top-level models field.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/deviceObject"},
          {"$ref": "#/$defs/deviceTuple"}
        ]
      }
    },
    "sizes": {
      "type": "object",
      "description": "Optional W/L sizes when not embedded in devices.",
      "additionalProperties": {"$ref": "#/$defs/sizeTuple"}
    },
    "nf": {
      "description": "Optional global NF integer or per-device NF map.",
      "oneOf": [
        {"type": "integer", "minimum": 1},
        {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 1}
        }
      ]
    },
    "bias": {
      "type": "object",
      "description": "Bias-key numeric values referenced by rails.",
      "additionalProperties": {"type": "number"}
    },
    "outputs": {
      "type": "array",
      "description": "One solved node for single-ended output, or two solved nodes for differential output.",
      "minItems": 1,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/name"}
    },
    "input_drives": {
      "type": "object",
      "description": "AC gate drive per device. Differential gain usually uses +0.5/-0.5.",
      "additionalProperties": {"type": "number"}
    },
    "ac_drives": {
      "type": "object",
      "description": "AC drive per named node, for source/passive-network inputs.",
      "additionalProperties": {"type": "number"}
    },
    "load_caps": {
      "type": "array",
      "description": "Fixed capacitances stamped in AC/noise/transient.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/loadCapObject"},
          {"$ref": "#/$defs/loadCapTuple"}
        ]
      }
    },
    "resistors": {
      "type": "array",
      "description": "Two-terminal resistors between nodes a and b (R in ohms).",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/resistorObject"},
          {"$ref": "#/$defs/abValueTuple"}
        ]
      }
    },
    "capacitors": {
      "type": "array",
      "description": "Two-terminal capacitors between nodes a and b (C in farads).",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/capacitorObject"},
          {"$ref": "#/$defs/abValueTuple"}
        ]
      }
    },
    "current_sources": {
      "type": "array",
      "description": "Ideal DC current sources; I (amps) flows nplus->nminus inside the source.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/isourceObject"},
          {"$ref": "#/$defs/isourceTuple"}
        ]
      }
    },
    "vccs": {
      "type": "array",
      "description": "Voltage-controlled current sources; I = gm*(Vcp - Vcn), current flows p->q.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/vccsObject"},
          {"$ref": "#/$defs/vccsTuple"}
        ]
      }
    },
    "vsources": {
      "type": "array",
      "description": "Ideal voltage sources (true MNA). Each adds a branch-current unknown and constraint V_p - V_q = value. value is a constant EMF (number) or a transient input-waveform key (string).",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/vsourceObject"},
          {"$ref": "#/$defs/vsourceTuple"}
        ]
      }
    },
    "vcvs": {
      "type": "array",
      "description": "Voltage-controlled voltage sources; V_p - V_q = mu*(V_cp - V_cn), adds a branch current.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/vcvsObject"},
          {"$ref": "#/$defs/vcvsTuple"}
        ]
      }
    },
    "cccs": {
      "type": "array",
      "description": "Current-controlled current sources; I_p->q = beta * I(ctrl_name branch source).",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/cccsObject"},
          {"$ref": "#/$defs/cccsTuple"}
        ]
      }
    },
    "ccvs": {
      "type": "array",
      "description": "Current-controlled voltage sources; V_p - V_q = gamma * I(ctrl_name branch source), adds a branch current.",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/ccvsObject"},
          {"$ref": "#/$defs/ccvsTuple"}
        ]
      }
    },
    "dc_guesses": {
      "type": "array",
      "description": "Optional DC initial guesses; each object maps solved node to voltage.",
      "items": {
        "type": "object",
        "additionalProperties": {"type": "number"}
      }
    },
    "aliases": {
      "type": "object",
      "description": "Optional dc_op aliases mapping alias name to solved node name.",
      "additionalProperties": {"$ref": "#/$defs/name"}
    },
    "transient_inputs": {
      "type": "object",
      "description": "Map device name to transient input waveform key.",
      "additionalProperties": {"$ref": "#/$defs/name"}
    },
    "periodic": {
      "$ref": "#/$defs/periodic",
      "description": "Default periodic large-signal excitation for PSS/PAC/PNoise."
    },
    "analyses": {
      "$ref": "#/$defs/analyses",
      "description": "Optional analysis dispatch configuration."
    },
    "adc": {
      "$ref": "#/$defs/adc",
      "description": "Optional ADC conversion workflow configuration."
    },
    "explore": {
      "$ref": "#/$defs/explore",
      "description": "Optional design-space exploration spec (see circuitopt/explore.py)."
    },
    "models": {
      "$ref": "#/$defs/models",
      "description": "Optional per-device model binding: PDK model-registry type + constructor kwargs (e.g. silicon SKY130 devices). Devices omitted here use the default PDK."
    }
  },
  "$defs": {
    "adc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "n_bits", "vref", "bit_inputs", "sample_input", "sample_bar_input", "comparator_node", "comparator_threshold", "sample_end", "bit_period", "edge_time"],
      "properties": {
        "type": {"const": "sar"},
        "n_bits": {"type": "integer", "minimum": 1},
        "vref": {"$ref": "#/$defs/positiveNumber"},
        "bit_inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/name"}},
        "bit_inputs_bar": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/name"}},
        "dummy_input": {"$ref": "#/$defs/name"},
        "dummy_input_bar": {"$ref": "#/$defs/name"},
        "input_common_mode": {"type": "number"},
        "sample_input": {"$ref": "#/$defs/name"},
        "sample_bar_input": {"$ref": "#/$defs/name"},
        "comparator_node": {"$ref": "#/$defs/name"},
        "comparator_threshold": {"type": "number"},
        "high_means_clear": {"type": "boolean"},
        "sample_end": {"$ref": "#/$defs/positiveNumber"},
        "bit_period": {"$ref": "#/$defs/positiveNumber"},
        "edge_time": {"$ref": "#/$defs/positiveNumber"},
        "points_per_period": {"type": "integer", "minimum": 8},
        "power_rails": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/name"}},
        "clock": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input"],
          "properties": {
            "input": {"$ref": "#/$defs/name"},
            "high": {"type": "number"},
            "low": {"type": "number"},
            "eval_before": {"$ref": "#/$defs/positiveNumber"},
            "reset_hold": {"type": "number", "minimum": 0}
          }
        },
        "mismatch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sigma_vth0": {"type": "number", "minimum": 0},
            "sigma_vth0_nmos": {"type": "number", "minimum": 0},
            "sigma_vth0_pmos": {"type": "number", "minimum": 0},
            "w0": {"$ref": "#/$defs/positiveNumber"},
            "l0": {"$ref": "#/$defs/positiveNumber"},
            "sigma_cu": {"type": "number", "minimum": 0},
            "c_unit": {"$ref": "#/$defs/positiveNumber"},
            "dnl_threshold": {"$ref": "#/$defs/positiveNumber"},
            "inl_threshold": {"$ref": "#/$defs/positiveNumber"}
          }
        }
      }
    },
    "models": {
      "type": "object",
      "description": "Device name -> {type, ...ctor kwargs}. 'type' is a model-registry key such as 'sky130.nmos'/'sky130.pmos'.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {"$ref": "#/$defs/name"},
          "vb": {"type": "number"},
          "corner": {"type": "string"},
          "extract_w": {"$ref": "#/$defs/positiveNumber"},
          "temperature": {"$ref": "#/$defs/positiveNumber"},
          "NF": {"type": "integer", "minimum": 1}
        }
      }
    },
    "analyses": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ac": {"$ref": "#/$defs/analysisCommon"},
        "noise": {"$ref": "#/$defs/analysisCommon"},
        "transient": {"$ref": "#/$defs/transientAnalysis"},
        "pss": {"$ref": "#/$defs/pssAnalysis"},
        "pac": {"$ref": "#/$defs/pacAnalysis"},
        "pnoise": {"$ref": "#/$defs/pnoiseAnalysis"}
      }
    },
    "analysisCommon": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "freqs": {"$ref": "#/$defs/frequencyGrid"},
        "band": {"$ref": "#/$defs/band"},
        "corner": {"$ref": "#/$defs/corner"}
      }
    },
    "pssAnalysis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "periodic": {"$ref": "#/$defs/periodic"},
        "n_points": {"type": "integer", "minimum": 2},
        "tgrid": {"$ref": "#/$defs/timeGrid"},
        "tstab_periods": {"type": "integer", "minimum": 0},
        "max_step": {"$ref": "#/$defs/positiveNumber"},
        "flat_max_step": {"$ref": "#/$defs/positiveNumber"},
        "max_retry_subdivisions": {"type": "integer", "minimum": 0},
        "newton_maxit": {"type": "integer", "minimum": 1},
        "newton_step_limit": {"$ref": "#/$defs/positiveNumber"},
        "newton_vtol": {"$ref": "#/$defs/positiveNumber"},
        "fallback_full_jacobian": {"type": "boolean"},
        "fallback_least_squares": {"type": "boolean"},
        "fallback_tol": {"$ref": "#/$defs/positiveNumber"},
        "max_shooting_iters": {"type": "integer", "minimum": 0},
        "residual_tol": {"$ref": "#/$defs/positiveNumber"},
        "fd_step": {"$ref": "#/$defs/positiveNumber"},
        "min_damping": {"$ref": "#/$defs/positiveNumber"},
        "jacobian_reuse": {"type": "boolean"},
        "jacobian_rebuild_interval": {"type": "integer", "minimum": 0},
        "analytic_jacobian": {"type": "boolean"},
        "rail_margin": {"type": "number"},
        "check_periodic_inputs": {"type": "boolean"},
        "input_periodic_tol": {"$ref": "#/$defs/positiveNumber"},
        "profile": {"type": "boolean"},
        "integration_method": {"type": "string", "enum": ["gear2", "be"]},
        "physical_factor": {"$ref": "#/$defs/positiveNumber"},
        "max_stabilization_periods": {"type": "integer", "minimum": 0},
        "levenberg_marquardt": {"type": "boolean"},
        "cap_mode": {"type": "string", "enum": ["charge", "q", "qstamp", "q-stamp", "average", "avg", "trapezoid", "trap"]},
        "cap_mode_id": {"type": "integer", "minimum": 0, "maximum": 1},
        "adaptive": {"type": "boolean"},
        "adaptive_reltol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_vabstol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_iabstol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_max_steps": {"type": "integer", "minimum": 1},
        "adaptive_h0": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_freeze_factor": {"$ref": "#/$defs/positiveNumber"},
        "corner": {"$ref": "#/$defs/corner"}
      }
    },
    "pacAnalysis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "freqs": {"$ref": "#/$defs/frequencyGrid"},
        "input_drive": {"$ref": "#/$defs/complexMap"},
        "pss": {"$ref": "#/$defs/pssAnalysis"},
        "fd_state_step": {"$ref": "#/$defs/positiveNumber"},
        "fd_input_step": {"$ref": "#/$defs/positiveNumber"},
        "transient_kwargs": {"type": "object", "additionalProperties": true},
        "analytic": {"type": "boolean"},
        "max_sideband": {"type": "integer", "minimum": 0},
        "n_period_samples": {"type": "integer", "minimum": 2},
        "time_domain": {"type": "boolean"},
        "td_integration": {"type": "string", "enum": ["gear2", "be"]},
        "td_n_period_samples": {"type": "integer", "minimum": 2},
        "pacmag": {"type": "number"},
        "rail_margin": {"type": ["number", "null"]},
        "cache_linearization": {"type": "boolean"},
        "cache_forcing": {"type": "boolean"},
        "compute_condition": {"type": ["boolean", "null"]},
        "profile": {"type": "boolean"},
        "debug": {"type": "boolean"},
        "lti_fast_path": {"type": "boolean"},
        "corner": {"$ref": "#/$defs/corner"}
      }
    },
    "pnoiseAnalysis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "freqs": {"$ref": "#/$defs/frequencyGrid"},
        "band": {"$ref": "#/$defs/band"},
        "input_drive": {"$ref": "#/$defs/complexMap"},
        "max_sideband": {"type": "integer", "minimum": 0},
        "n_period_samples": {"type": "integer", "minimum": 2},
        "time_domain": {"type": "boolean"},
        "noise_devices": {"type": ["array", "null"], "items": {"$ref": "#/$defs/name"}},
        "gds_noise_devices": {"type": ["array", "null"], "items": {"$ref": "#/$defs/name"}},
        "switch_noise_conductance_gated": {"type": "boolean"},
        "cache_linearization": {"type": "boolean"},
        "hb_solver": {"enum": ["auto", "dense", "sparse", "iterative"]},
        "hb_sparse_min_size": {"type": "integer", "minimum": 1},
        "hb_sparse_max_density": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "hb_sparse_drop_tol": {"type": "number", "minimum": 0.0},
        "iterative_tol": {"type": "number", "exclusiveMinimum": 0.0},
        "iterative_maxiter": {"type": ["integer", "null"], "minimum": 1},
        "profile": {"type": "boolean"},
        "lti_fast_path": {"type": "boolean"},
        "pss": {"$ref": "#/$defs/pssAnalysis"},
        "corner": {"$ref": "#/$defs/corner"}
      }
    },
    "transientAnalysis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tgrid": {"$ref": "#/$defs/timeGrid"},
        "periodic": {"$ref": "#/$defs/periodic"},
        "duration": {"$ref": "#/$defs/positiveNumber"},
        "tstop": {"$ref": "#/$defs/positiveNumber"},
        "n_points": {"type": "integer", "minimum": 2},
        "max_step": {"$ref": "#/$defs/positiveNumber"},
        "flat_max_step": {"$ref": "#/$defs/positiveNumber"},
        "max_retry_subdivisions": {"type": "integer", "minimum": 0},
        "newton_maxit": {"type": "integer", "minimum": 1},
        "newton_step_limit": {"$ref": "#/$defs/positiveNumber"},
        "newton_vtol": {"$ref": "#/$defs/positiveNumber"},
        "fallback_full_jacobian": {"type": "boolean"},
        "fallback_least_squares": {"type": "boolean"},
        "fallback_tol": {"$ref": "#/$defs/positiveNumber"},
        "profile": {"type": "boolean"},
        "rail_margin": {"type": "number"},
        "integration_method": {"type": "string", "enum": ["gear2", "be"]},
        "gear2_be_fallback": {"type": "boolean"},
        "cap_mode": {"type": "string", "enum": ["charge", "q", "qstamp", "q-stamp", "average", "avg", "trapezoid", "trap"]},
        "cap_mode_id": {"type": "integer", "minimum": 0, "maximum": 1},
        "adaptive": {"type": "boolean"},
        "adaptive_reltol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_vabstol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_iabstol": {"$ref": "#/$defs/positiveNumber"},
        "adaptive_max_steps": {"type": "integer", "minimum": 1},
        "adaptive_h0": {"$ref": "#/$defs/positiveNumber"},
        "corner": {"$ref": "#/$defs/corner"}
      }
    },
    "periodic": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency": {"$ref": "#/$defs/positiveNumber"},
        "fundamental": {"$ref": "#/$defs/positiveNumber"},
        "period": {"$ref": "#/$defs/positiveNumber"},
        "n_points": {"type": "integer", "minimum": 2},
        "tgrid": {"$ref": "#/$defs/timeGrid"},
        "inputs": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/waveform"}
        },
        "node_inputs": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/name"}
        },
        "current_inputs": {
          "type": "array",
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/currentInputObject"},
              {"$ref": "#/$defs/currentInputTuple"}
            ]
          }
        },
        "signed_devices": {"type": "array", "items": {"$ref": "#/$defs/name"}}
      }
    },
    "waveform": {
      "oneOf": [
        {"type": "number"},
        {"$ref": "#/$defs/name"},
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {"enum": ["constant", "dc", "sine", "sin", "cosine", "cos", "square", "pulse", "pwl"]},
            "value": {"oneOf": [{"type": "number"}, {"$ref": "#/$defs/name"}]},
            "dc": {"oneOf": [{"type": "number"}, {"$ref": "#/$defs/name"}]},
            "offset": {"oneOf": [{"type": "number"}, {"$ref": "#/$defs/name"}]},
            "amplitude": {"type": "number"},
            "phase": {"type": "number"},
            "frequency": {"$ref": "#/$defs/positiveNumber"},
            "harmonic": {"type": "number"},
            "low": {"oneOf": [{"type": "number"}, {"$ref": "#/$defs/name"}]},
            "high": {"oneOf": [{"type": "number"}, {"$ref": "#/$defs/name"}]},
            "duty": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1},
            "delay": {"type": "number"},
            "rise": {"type": "number", "minimum": 0},
            "fall": {"type": "number", "minimum": 0},
            "times": {"type": "array", "items": {"type": "number"}, "minItems": 2},
            "values": {"type": "array", "items": {"type": "number"}, "minItems": 2}
          }
        }
      ]
    },
    "frequencyGrid": {
      "oneOf": [
        {"type": "array", "items": {"$ref": "#/$defs/positiveNumber"}, "minItems": 1},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "stop", "num"],
          "properties": {
            "start": {"$ref": "#/$defs/positiveNumber"},
            "stop": {"$ref": "#/$defs/positiveNumber"},
            "num": {"type": "integer", "minimum": 1},
            "scale": {"enum": ["log", "linear"]}
          }
        }
      ]
    },
    "timeGrid": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {"type": "number"},
        "stop": {"type": "number"},
        "duration": {"$ref": "#/$defs/positiveNumber"},
        "n_points": {"type": "integer", "minimum": 2},
        "points": {"type": "array", "items": {"type": "number"}, "minItems": 2}
      }
    },
    "complexMap": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/complexValue"}
    },
    "complexValue": {
      "oneOf": [
        {"type": "number"},
        {
          "type": "array",
          "prefixItems": [{"type": "number"}, {"type": "number"}],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "real": {"type": "number"},
            "imag": {"type": "number"}
          }
        }
      ]
    },
    "corner": {
      "description": "Process corner name or explicit PMOS_TFT model-shift map.",
      "oneOf": [
        {"enum": ["typical", "slow", "fast"]},
        {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {"type": "number"},
              {
                "type": "object",
                "additionalProperties": {"type": "number"}
              }
            ]
          }
        }
      ]
    },
    "currentInputObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p", "q", "input"],
      "properties": {
        "p": {"$ref": "#/$defs/name"},
        "q": {"$ref": "#/$defs/name"},
        "input": {"$ref": "#/$defs/name"}
      }
    },
    "currentInputTuple": {
      "type": "array",
      "prefixItems": [{"$ref": "#/$defs/name"}, {"$ref": "#/$defs/name"}, {"$ref": "#/$defs/name"}],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "band": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "explore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variables", "objectives"],
      "properties": {
        "variables": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["min", "max"],
            "properties": {
              "min": {"type": "number"},
              "max": {"type": "number"},
              "targets": {"type": "array", "items": {"$ref": "#/$defs/name"}, "minItems": 1},
              "round": {"type": "integer", "minimum": 0},
              "int": {"type": "boolean"}
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {"min": {"type": "number"}, "max": {"type": "number"}}
          }
        },
        "objectives": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"enum": ["min", "max"]}
        },
        "band": {
          "type": "array",
          "prefixItems": [{"type": "number"}, {"type": "number"}],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "freqs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start": {"type": "number"},
            "stop": {"type": "number"},
            "num": {"type": "integer", "minimum": 2}
          }
        }
      }
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "positiveNumber": {
